{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-plugin-media-editorexamplesmedia-editor-example",
  "version": "0.1.0",
  "identifier": "com.zero.tauri-plugin-media-editorexamplesmedia-editor-example",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tauri-plugin-media-editorexamplesmedia-editor-example",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'; media-src 'self' asset: https://asset.localhost blob:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPCACHE/**",
          "$APPLOCALDATA/**",
          "$RESOURCE/**",
          "$TEMP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$AUDIO/**",
          "$VIDEO/**",
          "$PICTURE/**",
          "$HOME/**",
          "/tmp/**",
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
